%!TEX TS-program = xelatex
% Upstream Deedy Resume (OpenFonts variant) by Debarghya Das
% Source: https://github.com/deedy/Deedy-Resume (Apache 2.0)
% Trimmed to fit Deedy's one-page constraint.
% GENERATED FROM data/cv.yaml — edit yaml + run scripts/sync.py, not this file.

\documentclass[]{deedy-resume-openfont}
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}

\begin{document}

\lastupdated

\namesection{<< person.first_name >>}{<< person.last_name >>}{
  \urlstyle{same}\href{<< person.homepage_url >>}{<< person.homepage >>} $|$ \href{mailto:<< person.email >>}{<< person.email >>} \\
  << person.phone >> $|$ \href{https://github.com/<< person.github >>}{github.com/<< person.github >>} $|$ \href{https://linkedin.com/in/<< person.linkedin >>}{in/<< person.linkedin >>}
}

\begin{minipage}[t]{0.33\textwidth}

\section{Education}
<% for ed in education %>
\subsection{<< ed.org | replace("University", "Univ.") | replace("Kwangwoon Univ.", "Kwangwoon Univ.") >>}
\descript{<< ed.degree_short | replace(". ", ".\\ ") | replace("M.S.\\ in Computer Engineering", "M.S.\\ Computer Engineering") | replace("Graduate Research Program", "Grad Research, Mech \\& Ind. Eng.") | replace("B.S.\\ in Electronics and Communications Engineering", "B.S.\\ Electronics \\& Comms") >>}
\location{<< ed.end.split(". ")[0] if ". " in ed.end else ed.end >> << ed.end.split(". ")[1] if ". " in ed.end else "" >> $|$ <<
  ed.location.split(",")[0] >><% if ed.org == "University of Toronto" %><% else %>, << ed.location.split(",")[1].strip() >><% endif %>}
GPA << ed.gpa_compact >><% if "(" in ed.gpa %> (<< ed.gpa.split("(")[1].rstrip(")") | replace("%", "\\%") >>)<% endif %>
\sectionsep

<% endfor %>
\section{Links}
Github://~ \href{https://github.com/<< person.github >>}{\bf << person.github >>} \\
LinkedIn://~ \href{https://linkedin.com/in/<< person.linkedin >>}{\bf << person.linkedin >>}
\sectionsep

\section{Skills}
\subsection{Daily}
Python \textbullet{} PyTorch \textbullet{} Transformers \textbullet{} LangChain \textbullet{} Docker \textbullet{} CUDA
\sectionsep

\subsection{Familiar}
C/C++ \textbullet{} MATLAB \textbullet{} TensorFlow \textbullet{} scikit-learn
\sectionsep

\subsection{Domains}
Agentic AI \textbullet{} Multi-Agent LLM \textbullet{} GNN \textbullet{} Anomaly Detection
\sectionsep

\section{Awards}
<% set all_h = honors.major_awards + honors.academic_recognition + honors.competitions %>
<# Show top 6 most distinctive, ordered by date descending #>
<% for h in honors.competitions[:1] + honors.academic_recognition[:1] + honors.academic_recognition[1:2] + honors.academic_recognition[2:3] + honors.major_awards[:1] + honors.major_awards[1:2] %>
<< h.date.split(" ")[-1] >> \textbar{} \textbf{<< h.name.split(" ")[0] >><% if "Ministerial" in h.name %> Gold<% endif %>}, << h.event.split(" --- ")[0].split(",")[0] | replace("Conference of the ", "") | replace("23rd Embedded Software Competition (KIISE)", "KIISE Embedded SW") | replace("Institute of Electronics and Information Engineers", "IEIE Conf.") | replace("10th International Biomedical Engineering Conference (IBEC 2024)", "IBEC Best Poster") | replace("Conference of the Korean Society of Medical and Biological Engineering", "KOSOMBE") | replace("Korean Society of Medical and Biological Engineering", "KOSOMBE") | replace("Qualcomm Institute AI Development Project", "UCSD QC Inst.") | replace("2021 Smart Maritime Logistics Project", "Maritime Logistics") >><% if not loop.last %> \\<% endif %>

<% endfor %>

\sectionsep

\section{Patents}
<% for pat in patents %>
<< pat.number >> \\
\textit{<< pat.title_short if pat.title_short is defined else pat.title >>}<% if not loop.last %> \\[0.3em]
<% endif %>
<% endfor %>

\end{minipage}
\hfill
\begin{minipage}[t]{0.66\textwidth}

\section{Experience}

<% for e in experience %>
\runsubsection{<< e.org_short if e.org_short is defined else e.org >>}
\descript{$|$ << e.role | replace("AI Engineer, Intelligent Agent Technology Team", "AI Engineer, Intelligent Agent Team") | replace("AI Development Project Participant, Summer Program", "AI Development (Summer)") >>}
\location{<< e.start | replace(". ", " ") >> -- << e.end | replace(". ", " ") >> $|$ << e.location_short if e.location_short is defined else e.location >>}
\vspace{0.4em}
\begin{tightemize}
<% for b in (e.bullets_compact if e.bullets_compact is defined else e.bullets) %>
\item << b >>
<% endfor %>
\end{tightemize}
\sectionsep

<% endfor %>
\section{Research \& Projects}

<% for p in projects[:3] %>
\runsubsection{<< p.title_short if p.title_short is defined else p.title | replace("AI Intrusion Detection for APR1400 Nuclear Reactors", "AI Intrusion Detection for APR1400") | replace("Quadruped Robot with Vision SLAM", "Quadruped Robot, Vision SLAM") >>} \descript{$|$ <% if "LG Electronics" in p.org %>LG Canada<% elif "Sejong" in p.org %>Sejong U.<% elif "Ministry of Science" in p.org %>MSIT<% else %><< p.org >><% endif %>}
\location{<% if p.end == "Present" %><< p.start.split(" ")[-1] >> -- Present<% else %><% if p.start.split(" ")[-1] == p.end.split(" ")[-1] %><< p.start.split(".")[0] >> -- << p.end | replace(". ", " ") >><% else %><< p.start.split(" ")[-1] >> -- << p.end.split(" ")[-1] >><% endif %><% endif %>}
<< p.description | replace("Developed an evaluation framework for agentic AI systems using LLMs to assess performance.", "LLM-based evaluation framework for agentic AI systems.") | replace("Developed an AI defense system to protect nuclear power plants from cyber attacks.", "AI defense for nuclear plant control networks.") | replace("Developed an autonomous quadruped robot using a navigation algorithm with SLAM and a depth camera.", "Autonomous SLAM + depth-camera navigation.") >>
\sectionsep

<% endfor %>
\section{Publications}
<% for pub in publications.conferences %>
<< pub.authors >>\ ``<< pub.title_short if pub.title_short is defined else pub.title >>,'' \emph{<< pub.venue_short | replace("Industry Track", "Industry") >>}<% if pub.award is defined %> --- << pub.award.replace("Best Poster Award --- Silver.", "Best Poster Silver").rstrip(".") >><% endif %>.<% if not loop.last %>\\[0.15em]
<% endif %>

<% endfor %>
\end{minipage}
\end{document}
