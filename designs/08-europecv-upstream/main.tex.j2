% Upstream EuropeCV (Europass format) by Nicola Vitacolonna / Giuseppe Silano
% Source: https://ctan.org/pkg/europecv (LPPL)
% GENERATED FROM data/cv.yaml — edit yaml + run scripts/sync.py, not this file.

\documentclass[helvetica,narrow]{europecv}

\usepackage[T1]{fontenc}
\usepackage{lmodern}
\usepackage{graphicx}
\usepackage[english]{babel}
\usepackage{url}
\usepackage{hyperref}
\usepackage[a4paper,left=2cm,right=2cm,top=2cm,bottom=3cm]{geometry}

\ecvname{<< person.last_name >>, << person.first_name >>}
\ecvfootername{<< person.first_name >> << person.last_name >>}
\ecvaddress{<< person.address_line1 >>, << person.address_line2 >>}
\ecvtelephone{<< person.phone | replace(" ", "~") >>}
\ecvemail{\href{mailto:<< person.email >>}{<< person.email >>}}
\ecvhomepage{\url{<< person.homepage_url >>}}
\ecvnationality{Republic of Korea}
\ecvdateofbirth{}
\ecvgender{Male}
\ecvbeforepicture{\raggedleft}
\ecvpicture[height=3cm]{profile}
\ecvafterpicture{\ecvspace{-3.5cm}}
\ecvdate{\today}

\begin{document}
\selectlanguage{english}
\begin{europecv}

\ecvpersonalinfo

\section{Work experience}

<% for e in experience %>
\ecvitem{<< e.start | replace(". ", ".~") >> -- << e.end | replace(". ", ".~") >>}{\textbf{<< e.role.split(",")[0] >>}<% if "," in e.role %>, << e.role.split(",", 1)[1].strip() >><% endif %>\newline
  << e.org_short if e.org_short is defined else e.org >>, << e.location >>\newline
  \emph{Main activities:} <% for b in e.bullets %><< b >> <% endfor %>}

<% endfor %>
\section{Education and training}

<% for ed in education %>
\ecvitem{<< ed.start | replace(". ", ".~") >> -- << ed.end | replace(". ", ".~") >>}{\textbf{<< ed.degree >>}\newline
  << ed.org >>, << ed.location >>\newline
  GPA: << ed.gpa | replace("%", "\\%") >>.<% if ed.notes is defined %> << ed.notes >><% endif %>}

<% endfor %>
\section{Personal skills and competences}

\ecvmothertongue{<< spoken_languages[0].lang >>}
\ecvlanguageheader{(*)}
<% for sl in spoken_languages[1:] %>
\ecvlanguage{<< sl.lang >>}{\ecv<< sl.cef.replace("A1","AOne").replace("A2","ATwo").replace("B1","BOne").replace("B2","BTwo").replace("C1","COne").replace("C2","CTwo") >>}{\ecvCOne}{\ecvBTwo}{\ecvBTwo}{\ecvBTwo}
<% endfor %>
\ecvlanguagefooter{(*)}

\ecvitem{Technical skills}{\textbf{Languages:} << skills.languages | join(", ") >>.\newline
  \textbf{Frameworks:} << skills.frameworks | join(", ") >>.\newline
  \textbf{Tools:} << skills.tools | join(", ") >>.\newline
  \textbf{Domains:} << skills.domains | join(", ") >>.}

\ecvitem{Social skills}{Cross-cultural collaboration across Korean, Canadian, and
  US research environments. Former President of the Kwangwoon International
  Student Association and Class Representative for the Department of Electronics
  and Communications Engineering.}

\ecvitem{Organisational skills}{Director of Filming and Editing at Kwangwoon
  Broadcasting Center (KWBC). Executive Member of the Amateur Radio Club ---
  organised radio workshops and technical exhibitions.}

\section{Honours and awards}

<% for h in honors.major_awards + honors.academic_recognition + honors.competitions[:1] %>
\ecvitem{<< h.date | replace(". ", ".~") >>}{\textbf{<< h.name >>}, << h.event >>, << h.country >>.}
<% endfor %>

\section{Publications}

<% for pub in publications.conferences %>
\ecvitem{<< pub.year >>}{<< pub.authors >>,
  ``<< pub.title >>,''
  \emph{<< pub.venue_short >>}.<% if pub.note is defined %> << pub.note >><% endif %><% if pub.award is defined %> \textbf{<< pub.award >>}<% endif %>}

<% endfor %>
<% for pub in publications.journals if pub.details == "under review" %>
\ecvitem{<< pub.year >>}{\textbf{D.~Kwon} et al., ``<< pub.title >>,'' under review at
  \emph{<< pub.venue | replace("(Springer Nature)", "") | trim >>} (Springer Nature).}

<% endfor %>

\section{Patents}

<% for pat in patents %>
\ecvitem{<< pat.date_short | replace(" ", ".~") >>}{\textbf{<< pat.number >>} --- << pat.title >>.}
<% endfor %>

\end{europecv}
\end{document}
