%!TEX TS-program = xelatex
% Upstream AltaCV by LianTze Lim
% Source: https://github.com/liantze/AltaCV (LPPL 1.3+)
% GENERATED FROM data/cv.yaml — edit yaml + run scripts/sync.py, not this file.

\documentclass[10pt,letterpaper,withhyper]{altacv}

\geometry{left=1.25cm,right=1.25cm,top=1.5cm,bottom=1.5cm,columnsep=1.2cm}
\usepackage{paracol}

% AltaCV's native fonts. Roboto Slab comes from TeX Live's `roboto` package
% (Bold variant requires explicit mapping below). Lato is in ~/.fonts/.
\setmainfont{Roboto Slab}[
  UprightFont=RobotoSlab-Regular.otf,
  BoldFont=RobotoSlab-Bold.otf,
]
\setsansfont{Lato}
\renewcommand{\familydefault}{\sfdefault}

% Color palette
\definecolor{SlateGrey}{HTML}{2E2E2E}
\definecolor{LightGrey}{HTML}{666666}
\definecolor{DarkPastelRed}{HTML}{450808}
\definecolor{PastelRed}{HTML}{8F0D0D}
\definecolor{GoldenEarth}{HTML}{E7D192}
\colorlet{name}{black}
\colorlet{tagline}{PastelRed}
\colorlet{heading}{DarkPastelRed}
\colorlet{headingrule}{GoldenEarth}
\colorlet{subheading}{PastelRed}
\colorlet{accent}{PastelRed}
\colorlet{emphasis}{SlateGrey}
\colorlet{body}{LightGrey}

\renewcommand{\namefont}{\Huge\rmfamily\bfseries}
\renewcommand{\personalinfofont}{\footnotesize}
\renewcommand{\cvsectionfont}{\LARGE\rmfamily\bfseries}
\renewcommand{\cvsubsectionfont}{\large\bfseries}
\renewcommand{\cvItemMarker}{{\small\textbullet}}
\renewcommand{\cvRatingMarker}{\faCircle}

\begin{document}
\name{<< person.first_name >> << person.last_name >>}
\tagline{<< person.tagline | replace("▪", "\\textbullet\\") | replace("&", "\\&") >>}
\photoR{2.8cm}{profile}

\personalinfo{%
  \email{<< person.email >>}
  \phone{<< person.phone >>}
  \location{<< person.city_country >>}
  \homepage{<< person.homepage >>}
  \linkedin{<< person.linkedin >>}
  \github{<< person.github >>}
}

\makecvheader

\columnratio{0.62}
\begin{paracol}{2}

% ===== LEFT COLUMN =====
\cvsection{Experience}

<% for e in experience %>
\cvevent{<< e.role >>}{<< e.org_short if e.org_short is defined else e.org >>}{<< e.start | replace(". ", " ") >> -- << e.end | replace(". ", " ") >>}{<< e.location_short if e.location_short is defined else e.location >>}
\begin{itemize}
<% for b in e.bullets %>
\item << b | replace("--", "-") >>
<% endfor %>
\end{itemize}
<% if not loop.last %>

\divider

<% endif %>
<% endfor %>

\cvsection{Selected Publications}

<% for pub in publications.conferences %>
\cvevent{<< pub.title_short if pub.title_short is defined else pub.title >>}{<< pub.venue_short >><% if pub.award is defined %> --- << pub.award.rstrip(".") >><% endif %>}{<< pub.year >>}{}
<% if pub.note is defined %>
\textbf{D.~Kwon}$^{\dagger}$ et al. << pub.note >>
<% endif %>
<% if not loop.last %>

\divider

<% endif %>
<% endfor %>

\divider

<% for pub in publications.journals if pub.details == "under review" %>
\cvevent{<< pub.title >>}{<< pub.venue >> --- under review}{<< pub.year >>}{}
<% endfor %>

\cvsection{Patents}

<% for pat in patents %>
\cvevent{<< pat.title >>}{<< pat.number >>}{<< pat.date_short >>}{}
<% if not loop.last %>
\divider
<% endif %>
<% endfor %>

\switchcolumn

% ===== RIGHT COLUMN =====
\cvsection{Education}

<% for ed in education %>
\cvevent{<< ed.degree_short | replace(". ", ".\\ ") | replace("M.S.\\ in ", "M.S.\\ ") | replace("B.S.\\ in ", "B.S.\\ ") >>}{<< ed.org >>}{<< ed.start | replace(". ", " ") >> -- << ed.end | replace(". ", " ") >>}{<< ed.location >>}
GPA: << ed.gpa_compact >><% if "(" in ed.gpa %> (<< ed.gpa.split("(")[1].rstrip(")") | replace("%", "\\%") >>)<% endif %>
<% if not loop.last %>

\divider

<% endif %>
<% endfor %>

\cvsection{Most Proud of}

<% for h in honors.major_awards + honors.academic_recognition + honors.competitions %>
\cvachievement{\faTrophy}{<< h.name >>}{<< h.event >>, << h.date.split(" ")[-1] >>}
<% if not loop.last %>
\divider
<% endif %>
<% endfor %>

\cvsection{Skills}

<% for lang in skills.languages %>\cvtag{<< lang >>}<% endfor %>\\
<% for fw in skills.frameworks[:3] %>\cvtag{<< fw >>}<% endfor %>\\
<% for tool in skills.tools[:3] %>\cvtag{<< tool >>}<% endfor %>

\divider\smallskip

<% for d in skills.domains %>\cvtag{<< d >>}<% endfor %>

\cvsection{Languages}

<% for sl in spoken_languages %>
\cvskill{<< sl.lang >>}{<% if sl.level == "Native" %>5<% else %>4<% endif %>}
<% if not loop.last %>\divider<% endif %>
<% endfor %>

\cvsection{Leadership}

<% for l in leadership[:3] %>
\cvevent{<< l.role >>}{<< l.org >>}{}{}
<% if not loop.last %>\divider<% endif %>
<% endfor %>

\end{paracol}

\end{document}
