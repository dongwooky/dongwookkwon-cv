% Upstream Twenty Seconds Curriculum Vitae by Carmine Spagnuolo
% Source: https://github.com/spagnuolocarmine/TwentySecondsCurriculumVitae-LaTex (MIT)
% GENERATED FROM data/cv.yaml — edit yaml + run scripts/sync.py, not this file.

\documentclass[]{twentysecondcv}

\begin{document}

\profilepic{profile.jpg}
\cvname{<< person.first_name >> << person.last_name >>}
\cvjobtitle{AI Engineer}
\cvaddress{<< person.city_country >>}
\cvnumberphone{<< person.phone >>}
\cvmail{<< person.email >>}
\cvsite{<< person.homepage >>}

\aboutme{%
<< summary >>
}

\skills{%
<% for sb in skill_bars %>
  {<< sb.name >>/<< sb.level >>}<% if not loop.last %>,<% endif %>
<% endfor %>
}

\skillstext{<% for st in skill_tags %>{<< st.name >>/<< st.level >>}<% if not loop.last %>,<% endif %><% endfor %>}

\makeprofile

\section{about}
AI Engineer at Suresoft Technologies' Intelligent Agent Technology Team.
Master's in Computer Engineering at Kwangwoon University. Visiting research
at LG Electronics Canada with the University of Toronto.

\section{education}
\begin{twenty}
<% for ed in education %>
  \twentyitem
    {<< ed.start.split(" ")[-1] >><% if ed.start.split(" ")[-1] != ed.end.split(" ")[-1] %>--<< ed.end.split(" ")[-1] >><% endif %>}
    {<< ed.degree_short | replace("M.S. in Computer Engineering", "M.S.\\ {\\normalfont in Computer Engineering}") | replace("B.S. in Electronics and Communications Engineering", "B.S.\\ {\\normalfont in Electronics and Communications Engineering}") >>}
    {<< ed.org >><% if "Toronto" in ed.org %>, Canada<% else %>, << ed.location.split(",")[0] >><% endif %>}
    {GPA << ed.gpa_compact >><% if "(" in ed.gpa %> (<< ed.gpa.split("(")[1].rstrip(")") | replace("%", "\\%") >>)<% endif %>.<% if ed.notes is defined %> << ed.notes >><% endif %>}
<% endfor %>
\end{twenty}

\section{experience}
\begin{twenty}
<% for e in experience %>
  \twentyitem
    {<< e.start.split(" ")[-1] >><% if e.end == "Present" %>--Now<% elif e.start.split(" ")[-1] != e.end.split(" ")[-1] %>--<< e.end.split(" ")[-1] >><% endif %>}
    {<< e.role >>}
    {<< (e.org_short if e.org_short is defined else e.org) | replace("Kwangwoon University", "Kwangwoon U.") >><% if e.location_short is defined %>, << e.location_short.split(",")[0] >><% endif %>}
    {<% for b in (e.bullets_compact if e.bullets_compact is defined else e.bullets) %><< b >> <% endfor %>}
<% endfor %>
\end{twenty}

\section{publications}
\begin{twentyshort}
<% for pub in publications.conferences %>
  \twentyitemshort
    {<< pub.year >>}
    {\textbf{D. Kwon}<% if "$^{\\dagger}$" in pub.authors %>$^{\dagger}$<% endif %> et al.\ ``<< pub.title_short if pub.title_short is defined else pub.title >>.'' \emph{<< pub.venue_short | replace("Industry Track", "Industry") >>}<% if pub.award is defined %> --- << pub.award.replace("Best Poster Award --- Silver.", "Best Poster Silver").rstrip(".") >><% endif %>.}
<% endfor %>
<% for pub in publications.journals if pub.details == "under review" %>
  \twentyitemshort
    {<< pub.year >>}
    {\textbf{D. Kwon} et al.\ ``<< pub.title | replace("Power Generation Environments", "Power Generation") | replace("Bidirectional GRU", "Bi-GRU") >>.'' \emph{<< pub.venue | replace("Data Mining and Knowledge Discovery", "DMKD") | replace("(Springer Nature)", "") >>} (Springer Nature, under review).}
<% endfor %>
\end{twentyshort}

\section{awards}
\begin{twentyshort}
<% set top_awards = honors.competitions[:1] + honors.academic_recognition[:1] + honors.academic_recognition[1:2] + honors.major_awards[:1] + honors.major_awards[1:2] %>
<% for h in top_awards %>
  \twentyitemshort
    {<< h.date.split(" ")[-1] >>}
    {\textbf{<< h.name | replace(" (Ministerial Award)", "") | replace(" (Silver)", " Silver") | replace("Award", "") | trim >><% if "Ministerial" in h.name %> (Ministerial)<% endif %>}, << h.event | replace("Conference of the Institute of Electronics and Information Engineers", "IEIE Conference") | replace("10th International Biomedical Engineering Conference (IBEC 2024)", "IBEC 2024") | replace("23rd Embedded Software Competition (KIISE)", "23rd Embedded Software Competition (KIISE)") | replace("Qualcomm Institute AI Development Project --- UC San Diego", "Qualcomm Institute AI Project --- UC San Diego") | replace("2021 Smart Maritime Logistics Project --- Minister of Oceans and Fisheries", "Smart Maritime Logistics Project --- Minister of Oceans and Fisheries") >>.}
<% endfor %>
\end{twentyshort}

\section{patents}
\begin{twentyshort}
<% for pat in patents %>
  \twentyitemshort
    {<< pat.date_short >>}
    {<< pat.number >> --- << pat.title_short if pat.title_short is defined else pat.title >>.}
<% endfor %>
\end{twentyshort}

\end{document}
